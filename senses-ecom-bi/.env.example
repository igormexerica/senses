# senses-ecom-bi — variáveis server-only. Copie para .env (fora do git).
# O container (rede supabase_default) lê via env_file.

# --- Acesso (Basic Auth, login POR PESSOA) ---
# email:senha,email:senha,...  (senhas alfanuméricas, SEM ':' nem ',')
DASHBOARD_USERS=fulano@gruposenses.com.br:senhaForte1,ciclana@gruposenses.com.br:senhaForte2

# --- Banco (server-only) ---
# No container, o Postgres do Supabase é supabase-db:5432 (DNS interno do docker).
DATABASE_URL=postgresql://postgres:SENHA_DO_POSTGRES@supabase-db:5432/postgres

# --- Ingest Nuvemshop (financeiro) ---
NUVEMSHOP_STORE_ID=000000
NUVEMSHOP_TOKEN=seu_access_token
NUVEMSHOP_APP_NAME=SensesBI
NUVEMSHOP_CONTACT_EMAIL=contato@gruposenses.com.br

# --- Ingest GA4 (funil) ---
GA4_PROPERTY_ID=123456789
GOOGLE_APPLICATION_CREDENTIALS=/app/ga4-service-account.json
