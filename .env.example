# ─────────────────────────────────────────────────────────────
# Field Control API
# ─────────────────────────────────────────────────────────────
# Gerar em: https://app.fieldcontrol.com.br/#/configuracoes/configuracao-para-desenvolvedores
FIELD_CONTROL_API_KEY=

# ─────────────────────────────────────────────────────────────
# Supabase (log/audit de OS geradas)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─────────────────────────────────────────────────────────────
# Clint CRM
# ─────────────────────────────────────────────────────────────
CLINT_API_BASE=https://api.clint.digital
CLINT_API_KEY=

# ─────────────────────────────────────────────────────────────
# n8n (Contabo VPS) — base URL dos webhooks
# ─────────────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=

# ─────────────────────────────────────────────────────────────
# Telegram — notificações ao gestor de CS
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_GESTOR_CS=

# ─────────────────────────────────────────────────────────────
# Microserviço HTTP (Fastify)
# ─────────────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 32
API_INTERNAL_KEY=
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development
