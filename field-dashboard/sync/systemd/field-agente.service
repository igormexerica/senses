[Unit]
Description=Agente classificador (Claude) de comentarios e avaliacoes
Documentation=file:/root/senses/field-dashboard/sync/PROMPT-BLOCO2-CLAUDE-CODE.md
After=network-online.target field-sync.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/senses/field-dashboard/sync
ExecStart=/root/senses/field-dashboard/sync/.venv/bin/python agente_classificador.py
TimeoutStartSec=900
Nice=10

[Install]
WantedBy=multi-user.target
