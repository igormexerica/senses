# ---------------------------------------------------------------------------
# field-dashboard / sync — variaveis de ambiente
# Copie para .env e preencha:  cp .env.example .env && chmod 600 .env
# NAO comite o .env. Valores reais ficam no password manager do Igor.
# ---------------------------------------------------------------------------

# --- Field Control (origem do sync) ---------------------------------------
# Gerada no painel do Field. Enviada no header X-Api-Key.
FIELD_API_KEY=
# Base da API. Default do field_client.py se omitido.
FIELD_BASE_URL=https://carchost.fieldcontrol.com.br

# --- Supabase self-hosted (destino do sync) -------------------------------
# No mesmo host do Supabase use http://localhost:8000 (Kong).
SUPABASE_URL=http://localhost:8000
# SERVICE_ROLE_KEY (NAO a anon). Escreve no schema field via PostgREST.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (agente classificador) -------------------------------------
ANTHROPIC_API_KEY=
# Modelo usado pelo agente. Default do codigo se omitido.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- Tuning do sync (opcionais; defaults no run_sync.py) ------------------
# Clientes e equipamentos fazem full a cada run; estes gates evitam rodar
# o full a cada 30min (mudam pouco). Horas minimas entre fulls:
CLIENTES_MIN_HORAS=6
EQUIP_MIN_HORAS=6
# Workers paralelos para upserts (equipamentos) e /tasks (avaliacoes):
SYNC_WORKERS=6
